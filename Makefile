DOCKER_COMPOSE = docker compose -f ./docker-compose.yml

## =====================================================================================================================
## 	     					СПРАВКА
## =====================================================================================================================
help: ## Список доступных команд
	@grep -hE '(^[a-zA-Z_-]+:.*?##.*$$)|(^##)' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "\033[32m%-40s\033[0m %s\n", $$1, $$2}' | sed -e 's/\[32m##/[33m/'

## =====================================================================================================================
## 	     					Сборка образа
## =====================================================================================================================
build: ## Собать или пересобрать сервис
	${DOCKER_COMPOSE} build

## =====================================================================================================================
## 	     					Запуск и остановка
## =====================================================================================================================
start: ## Запустить сервис
	${DOCKER_COMPOSE} start

stop: ## Остановить сервис
	${DOCKER_COMPOSE} stop

up: ## Создать и запустить контейнер
	${DOCKER_COMPOSE} up -d --remove-orphans

down: ## Остановить и удалить контейнер, сеть
	${DOCKER_COMPOSE} down -v --rmi=all --remove-orphans

## =====================================================================================================================
## 	     					Утилиты
## =====================================================================================================================
bash: ## Зайти в консоль контейнера
	${DOCKER_COMPOSE} exec reticulum-meshchat bash
